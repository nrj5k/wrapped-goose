      { "syscall": "memfd_create" },
      { "syscall": "io_uring_setup" },
      { "syscall": "io_uring_enter" },
      { "syscall": "io_uring_register" },
      { "syscall": "pidfd_getfd" },
      { "syscall": "mount_setattr" },
      { "syscall": "fsopen" },
      { "syscall": "fsmount" },
      { "syscall": "fsconfig" },
      { "syscall": "open_tree" },
      { "syscall": "move_mount" },
      { "syscall": "kcmp" },
      {
        "syscall": "socket",
        "args": [{ "index": 0, "type": "dword", "op": "eq", "val": 17 }]
      },
      {
        "syscall": "socket",
        "args": [{ "index": 0, "type": "dword", "op": "eq", "val": 16 }]
      }
    ]
